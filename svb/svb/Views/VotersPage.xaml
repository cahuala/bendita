<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeneditaUI.Views.VotersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Eleitores"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="28,24" RowSpacing="16">

        <!-- ── Cabeçalho ─────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <VerticalStackLayout Spacing="2">
                <Label Text="Gestão de Eleitores" Style="{StaticResource PageTitle}" />
                <Label
                    Text="Cadastre eleitores e registe as suas impressões digitais"
                    Style="{StaticResource Caption}" />
            </VerticalStackLayout>
            <Button
                Grid.Column="1"
                Text="↺  Atualizar"
                Command="{Binding LoadCommand}"
                Style="{StaticResource SecondaryButton}" />
            <Button
                Grid.Column="2"
                Text="🗑  Remover"
                Command="{Binding DeleteCommand}"
                Style="{StaticResource DangerButton}" />
        </Grid>

        <!-- ── Banner de feedback ─────────────────────── -->
        <Frame
            Grid.Row="1"
            Style="{StaticResource FeedbackFrame}"
            BackgroundColor="{Binding FeedbackColor}"
            BorderColor="Transparent"
            IsVisible="{Binding HasFeedback}">
            <Label
                Text="{Binding FeedbackMessage}"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="13" />
        </Frame>

        <!-- ── Layout Master-Detail ───────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,380" ColumnSpacing="16">

            <!-- ═══ ESQUERDA — Lista de eleitores ════════ -->
            <Frame ColumnDefinitions="*" Style="{StaticResource CardFrame}" Padding="0">
                <Grid RowDefinitions="Auto,*">

                    <!-- Lista header -->
                    <Grid
                        Grid.Row="0"
                        Padding="20,16,20,12"
                        ColumnDefinitions="*,Auto">
                        <Label
                            Text="Lista de Eleitores"
                            Style="{StaticResource SectionHeader}" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding Voters.Count, StringFormat='{0} registo(s)'}"
                            Style="{StaticResource Caption}"
                            VerticalOptions="Center" />
                    </Grid>
                    <BoxView Grid.Row="0" VerticalOptions="End" Color="{StaticResource BorderLight}" HeightRequest="1" />

                    <!-- CollectionView -->
                    <CollectionView
                        Grid.Row="1"
                        ItemsSource="{Binding Voters}"
                        SelectedItem="{Binding SelectedVoter}"
                        SelectionMode="Single"
                        EmptyView="Nenhum eleitor cadastrado ainda.">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    ColumnDefinitions="4,Auto,*,Auto"
                                    ColumnSpacing="12"
                                    Padding="0,0,16,0">

                                    <!-- Accent left bar (status color) -->
                                    <BoxView
                                        Grid.Column="0"
                                        Color="{Binding StatusColor}"
                                        WidthRequest="4"
                                        VerticalOptions="Fill" />

                                    <!-- Avatar / BI badge -->
                                    <Frame
                                        Grid.Column="1"
                                        BackgroundColor="{StaticResource CreamMid}"
                                        CornerRadius="10"
                                        Padding="10,6"
                                        HasShadow="False"
                                        BorderColor="{StaticResource Border}"
                                        VerticalOptions="Center"
                                        Margin="0,10,0,10">
                                        <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                                            <Label
                                                Text="BI"
                                                FontSize="9"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource OnSurfaceMuted}"
                                                HorizontalOptions="Center" />
                                            <Label
                                                Text="{Binding BI}"
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                TextColor="{StaticResource OnSurface}"
                                                HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Frame>

                                    <!-- Nome + info -->
                                    <VerticalStackLayout
                                        Grid.Column="2"
                                        Spacing="3"
                                        VerticalOptions="Center"
                                        Padding="0,10">
                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="15"
                                            FontAttributes="Bold" />
                                        <Label
                                            Text="{Binding RegisteredAt, StringFormat='Cadastrado: {0:dd/MM/yyyy}'}"
                                            Style="{StaticResource Caption}" />
                                        <Label
                                            Text="{Binding FingerId, StringFormat='Digital: slot {0}'}"
                                            Style="{StaticResource Caption}"
                                            TextColor="{StaticResource Enroll}"
                                            IsVisible="{Binding HasFingerprint}" />
                                        <Label
                                            Text="{Binding Vote.Entity.Acronym, StringFormat='Votou: {0}'}"
                                            Style="{StaticResource Caption}"
                                            TextColor="{StaticResource Success}"
                                            IsVisible="{Binding Vote, Converter={StaticResource NullToBoolConverter}}" />
                                    </VerticalStackLayout>

                                    <!-- Status badge -->
                                    <Frame
                                        Grid.Column="3"
                                        BackgroundColor="{Binding StatusColor}"
                                        CornerRadius="8"
                                        Padding="10,4"
                                        HasShadow="False"
                                        BorderColor="Transparent"
                                        VerticalOptions="Center">
                                        <Label
                                            Text="{Binding StatusLabel}"
                                            TextColor="White"
                                            FontSize="11"
                                            FontAttributes="Bold" />
                                    </Frame>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>
            </Frame>

            <!-- ═══ DIREITA — Formulários ══════════════════ -->
            <VerticalStackLayout Grid.Column="1" Spacing="14">

                <!-- ── PASSO 1: Cadastrar eleitor ────────── -->
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="14">

                        <!-- Step header -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Frame Style="{StaticResource StepCircleActive}">
                                <Label
                                    Text="1"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label Text="Dados do Eleitor" Style="{StaticResource SectionHeader}" />
                                <Label Text="Nome completo e Bilhete de Identidade" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Color="{StaticResource BorderLight}" HeightRequest="1" />

                        <!-- Aviso de duplicado -->
                        <Frame
                            BackgroundColor="{StaticResource WarningLight}"
                            BorderColor="{StaticResource Warning}"
                            CornerRadius="8"
                            Padding="12,8"
                            HasShadow="False"
                            IsVisible="{Binding HasDuplicateWarning}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label
                                    Text="⚠"
                                    TextColor="{StaticResource Warning}"
                                    FontSize="16"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding DuplicateWarning}"
                                    TextColor="{StaticResource Warning}"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Frame>

                        <!-- Campo Nome -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="NOME COMPLETO" Style="{StaticResource FieldLabel}" />
                            <Frame Style="{StaticResource FieldFrame}">
                                <Entry
                                    Placeholder="Ex: João Manuel da Silva"
                                    Text="{Binding NewName}"
                                    HeightRequest="36" />
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Campo BI -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="BILHETE DE IDENTIDADE" Style="{StaticResource FieldLabel}" />
                            <Frame Style="{StaticResource FieldFrame}">
                                <Entry
                                    Placeholder="Ex: 007328941LA041"
                                    Text="{Binding NewBI}"
                                    HeightRequest="36" />
                            </Frame>
                        </VerticalStackLayout>

                        <Button
                            Text="Cadastrar Eleitor"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />

                        <ActivityIndicator
                            IsRunning="{Binding IsLoading}"
                            IsVisible="{Binding IsLoading}"
                            Color="{StaticResource Primary}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── PASSO 2: Registar impressão digital ─ -->

                <!-- Painel inativo (com instrução) -->
                <Frame
                    Style="{StaticResource CardFrameWarm}"
                    IsVisible="{Binding CanEnrollSelected}">
                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Frame Style="{StaticResource StepCircleIdle}">
                                <Label
                                    Text="2"
                                    TextColor="{StaticResource OnSurfaceMuted}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label Text="Impressão Digital" Style="{StaticResource SectionHeader}" />
                                <Label Text="Eleitor seleccionado — sem digital registada" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView Color="{StaticResource BorderLight}" HeightRequest="1" />

                        <Frame
                            BackgroundColor="{StaticResource EnrollLight}"
                            BorderColor="{StaticResource Enroll}"
                            CornerRadius="10"
                            Padding="14,10"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="{Binding SelectedVoter.Name, StringFormat='Eleitor: {0}'}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource Enroll}"
                                    FontSize="14" />
                                <Label
                                    Text="Peça ao eleitor para colocar o dedo no sensor e pressione o botão abaixo."
                                    TextColor="{StaticResource OnSurfaceMuted}"
                                    FontSize="12" />
                            </VerticalStackLayout>
                        </Frame>

                        <Button
                            Text="👆  Iniciar Registo de Digital"
                            Style="{StaticResource EnrollButton}"
                            Command="{Binding EnrollFingerprintCommand}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Em progresso -->
                <Frame
                    Style="{StaticResource CardFrameWarm}"
                    IsVisible="{Binding IsEnrolling}">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <ActivityIndicator
                            IsRunning="True"
                            Color="{StaticResource Enroll}"
                            WidthRequest="44"
                            HeightRequest="44"
                            HorizontalOptions="Center" />
                        <Label
                            Text="{Binding EnrollMessage}"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Enroll}"
                            FontSize="14"
                            HorizontalOptions="Center" />
                        <Label
                            Text="Aguarde até 30 segundos..."
                            Style="{StaticResource Caption}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Instrução quando nenhum eleitor seleccionado -->
                <Frame
                    Style="{StaticResource CardFrameWarm}"
                    IsVisible="{Binding CanEnrollSelected, Converter={StaticResource InverseBoolConverter}}">
                    <VerticalStackLayout
                        Spacing="4"
                        IsVisible="{Binding IsEnrolling, Converter={StaticResource InverseBoolConverter}}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Frame Style="{StaticResource StepCircleIdle}">
                                <Label
                                    Text="2"
                                    TextColor="{StaticResource OnSurfaceMuted}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label Text="Impressão Digital" Style="{StaticResource SectionHeader}" />
                                <Label
                                    Text="Selecione um eleitor sem digital na lista"
                                    Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
