<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeneditaUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Configurações"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="28,24" Spacing="20" MaximumWidthRequest="640">

            <!-- ── Cabeçalho ──────────────────────────── -->
            <VerticalStackLayout Spacing="2" Margin="0,0,0,4">
                <Label Text="Configurações" Style="{StaticResource PageTitle}" />
                <Label Text="Parâmetros de ligação e informações do sistema" Style="{StaticResource Caption}" />
            </VerticalStackLayout>

            <!-- ── Ligação à API ──────────────────────── -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame
                            BackgroundColor="{StaticResource PrimaryUltraLight}"
                            CornerRadius="10"
                            Padding="10"
                            HasShadow="False"
                            BorderColor="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                            <Label
                                Text="🔗"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                            <Label Text="Ligação à API" Style="{StaticResource SectionHeader}" />
                            <Label Text="Endereço do servidor SVB" Style="{StaticResource Caption}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView Color="{StaticResource BorderLight}" HeightRequest="1" />

                    <!-- URL field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="ENDEREÇO DA API" Style="{StaticResource FieldLabel}" />
                        <Frame Style="{StaticResource FieldFrame}">
                            <Entry
                                Text="{Binding ApiUrl}"
                                Placeholder="http://localhost:5000/"
                                Keyboard="Url"
                                HeightRequest="36" />
                        </Frame>
                        <Label
                            Text="Ex: http://192.168.1.10:5000/ para acesso em rede local"
                            Style="{StaticResource Caption}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="💾  Guardar"
                            Command="{Binding SaveUrlCommand}" />
                        <Button
                            Grid.Column="1"
                            Text="🔌  Testar Ligação"
                            Command="{Binding TestConnCommand}"
                            IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource SecondaryButton}" />
                    </Grid>

                    <!-- Resultado do ping -->
                    <Frame
                        BackgroundColor="{Binding PingColor}"
                        CornerRadius="10"
                        Padding="14,10"
                        HasShadow="False"
                        BorderColor="Transparent"
                        IsVisible="{Binding PingResult, Converter={StaticResource NullToBoolConverter}}">
                        <Label
                            Text="{Binding PingResult}"
                            TextColor="White"
                            HorizontalOptions="Center"
                            FontAttributes="Bold"
                            FontSize="13" />
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame
                            BackgroundColor="{StaticResource PrimaryUltraLight}"
                            CornerRadius="10"
                            Padding="10"
                            HasShadow="False"
                            BorderColor="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                            <Label
                                Text="🧩"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                            <Label Text="Porta COM (controlada pela app)" Style="{StaticResource SectionHeader}" />
                            <Label Text="A app lê portas locais e manda ao backend conectar" Style="{StaticResource Caption}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView Color="{StaticResource BorderLight}" HeightRequest="1" />

                    <Grid ColumnDefinitions="*,160" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PORTA COM" Style="{StaticResource FieldLabel}" />
                            <Frame Style="{StaticResource FieldFrame}">
                                <Picker
                                    Title="Selecione a porta"
                                    ItemsSource="{Binding AvailablePorts}"
                                    SelectedItem="{Binding SelectedPort}" />
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="BAUD RATE" Style="{StaticResource FieldLabel}" />
                            <Frame Style="{StaticResource FieldFrame}">
                                <Entry
                                    Text="{Binding BaudRateInput}"
                                    Keyboard="Numeric"
                                    Placeholder="115200" />
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="10">
                        <Button
                            Text="Atualizar"
                            Command="{Binding LoadSerialCommand}"
                            IsEnabled="{Binding IsSerialBusy, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource SecondaryButton}" />
                        <Button
                            Grid.Column="1"
                            Text="Conectar"
                            Command="{Binding ConnectSerialCommand}"
                            IsEnabled="{Binding CanConnectSerial}" />
                        <Button
                            Grid.Column="2"
                            Text="Desconectar"
                            Command="{Binding DisconnectSerialCommand}"
                            IsEnabled="{Binding CanDisconnectSerial}"
                            Style="{StaticResource DangerButton}" />
                    </Grid>

                    <Frame
                        Style="{StaticResource FeedbackFrame}"
                        BackgroundColor="{Binding SerialStatusColor}"
                        BorderColor="Transparent">
                        <Label
                            Text="{Binding SerialStatus}"
                            TextColor="White"
                            FontAttributes="Bold" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- ── Sobre ───────────────────────────────── -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame
                            BackgroundColor="{StaticResource PrimaryUltraLight}"
                            CornerRadius="10"
                            Padding="10"
                            HasShadow="False"
                            BorderColor="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                            <Label
                                Text="ℹ"
                                FontSize="22"
                                TextColor="{StaticResource Primary}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                            <Label Text="Sobre o Sistema" Style="{StaticResource SectionHeader}" />
                            <Label Text="SVB — Sistema de Votação Biométrica" Style="{StaticResource Caption}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView Color="{StaticResource BorderLight}" HeightRequest="1" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                        <Label Text="Hardware" Style="{StaticResource FieldLabel}" />
                        <Label Grid.Column="1" Text="ESP32 + Sensor Biométrico + LCD 16×2" FontSize="13" />

                        <Label Grid.Row="1" Text="API" Style="{StaticResource FieldLabel}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="ASP.NET Core 8 + MySQL" FontSize="13" />

                        <Label Grid.Row="2" Text="Interface" Style="{StaticResource FieldLabel}" />
                        <Label Grid.Row="2" Grid.Column="1" Text=".NET MAUI 10 (Windows)" FontSize="13" />

                        <Label Grid.Row="3" Text="Versão" Style="{StaticResource FieldLabel}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="v2.0.0" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
